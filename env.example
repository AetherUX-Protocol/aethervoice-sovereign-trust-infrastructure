# -----------------------------------
# AetherVoice Environment Variables
# -----------------------------------

# Application
APP_NAME=AetherVoice
APP_ENV=development
APP_PORT=8000

# SNS
SNS_NETWORK=solana-devnet
SNS_PROGRAM_ID=example_sns_program

# QVAC
QVAC_MODE=local
QVAC_MODEL=verification-engine-v1

# Umbra
UMBRA_NETWORK=solana-devnet
UMBRA_PRIVACY_MODE=enabled

# Wallet
DEFAULT_WALLET_PROVIDER=phantom

# Demo
ENABLE_DEMO_MODE=true
